<resources>

    <!-- 一般 App 主題（載入完成後使用） -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- 你的其他自訂，例如顏色、字型等 -->
        <item name="colorPrimary">#2196F3</item>
        <item name="colorPrimaryDark">#1976D2</item>
        <item name="colorAccent">#FF4081</item>
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
    </style>

    <!-- Splash Screen 專用主題（只在啟動時使用） -->
    <style name="AppTheme.Launch" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">#FFFFFF</item> <!-- 與背景色一致 -->
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item> <!-- 可改 true 做全螢幕 -->
    </style>

</resources>